<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<title>Standardowe sformułowania</title>

<style>
:root {
  --color-primary: #cc142e;
  --color-primary-hover: #d21d35;
  --color-border: #e5e5e5;
  --radius: 8px;
}

/* BASE */
body {
  margin: 0;
  font-family: Arial;
  background: #fbfbfb;
}

.main {
  padding: 20px;
}

.container-wide {
  max-width: 1400px;
  margin: 0 auto;
  padding: 25px;
  background: #fff;
  border-radius: var(--radius);
  box-shadow: 0 6px 20px rgba(0,0,0,0.06);
}

.container-card {
  border: 1px solid var(--color-border);
  border-radius: var(--radius);
  padding: 15px;
  margin-bottom: 20px;
}

/* TEXT ITEMS */
.copy-item {
  padding: 10px;
  border-bottom: 1px solid var(--color-border);
  cursor: pointer;
}

.copy-item:hover {
  color: var(--color-primary);
  background: #fff5f6;
}

.copy-item:last-child {
  border-bottom: none;
}

/* HEADINGS */
h1 { margin-bottom: 20px; }
h2 { margin-bottom: 10px; }

</style>
</head>

<body>

<div class="main">
  <div class="container-wide">

    <h1>Standardowe sformułowania</h1>

    <!-- ================= POWITANIE ================= -->
    <div class="container-card">
      <h2>Powitanie</h2>

      <div class="copy-item" onclick="copyText(this)">
        Dzień dobry, w czym mogę pomóc?
      </div>

      <div class="copy-item" onclick="copyText(this)">
        Dzień dobry, dziękuję za kontakt z serwisem AEG.
      </div>
    </div>

    <!-- ================= WERYFIKACJA ================= -->
    <div class="container-card">
      <h2>Weryfikacja danych</h2>

      <div class="copy-item" onclick="copyText(this)">
        Czy mogę prosić o podanie numeru zgłoszenia?
      </div>

      <div class="copy-item" onclick="copyText(this)">
        Proszę o potwierdzenie adresu wizyty.
      </div>
    </div>

    <!-- ================= INFORMOWANIE ================= -->
    <div class="container-card">
      <h2>Informowanie klienta</h2>

      <div class="copy-item" onclick="copyText(this)">
        Już sprawdzam status zgłoszenia.
      </div>

      <div class="copy-item" onclick="copyText(this)">
        Proszę o chwilę cierpliwości.
      </div>
    </div>

    <!-- ================= TERMIN ================= -->
    <div class="container-card">
      <h2>Ustalanie terminu</h2>

      <div class="copy-item" onclick="copyText(this)">
        Proszę wskazać dogodny termin wizyty.
      </div>

      <div class="copy-item" onclick="copyText(this)">
        Czy ten termin jest dla Pana/Pani odpowiedni?
      </div>
    </div>

    <!-- ================= PROBLEM ================= -->
    <div class="container-card">
      <h2>Problem / diagnoza</h2>

      <div class="copy-item" onclick="copyText(this)">
        Proszę opisać problem z urządzeniem.
      </div>

      <div class="copy-item" onclick="copyText(this)">
        Czy urządzenie było wcześniej naprawiane?
      </div>
    </div>

    <!-- ================= ZAKOŃCZENIE ================= -->
    <div class="container-card">
      <h2>Zakończenie rozmowy</h2>

      <div class="copy-item" onclick="copyText(this)">
        Czy mogę pomóc w czymś jeszcze?
      </div>

      <div class="copy-item" onclick="copyText(this)">
        Dziękuję za rozmowę i życzę miłego dnia.
      </div>
    </div>

  </div>
</div>

<script>
function copyText(el) {
  const text = el.innerText;

  navigator.clipboard.writeText(text);

  const original = el.innerText;
  el.innerText = "Skopiowano ✓";

  setTimeout(() => {
    el.innerText = original;
  }, 1500);
}
</script>

</body>
</html>