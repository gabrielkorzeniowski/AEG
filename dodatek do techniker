<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8">
<title>Technik Edit</title>

<style>
:root {
  --color-primary: #cc142e;
  --color-primary-hover: #d21d35;
  --color-border: #e5e5e5;
  --radius: 8px;
}

/* BASE */
body {
  margin: 0;
  font-family: Arial;
  background: #fbfbfb;
}

.main {
  padding: 20px;
}

.container-wide {
  max-width: 1400px;
  margin: 0 auto;
  padding: 25px;
  background: #fff;
  border-radius: var(--radius);
  box-shadow: 0 6px 20px rgba(0,0,0,0.06);
}

.container-card {
  border: 1px solid var(--color-border);
  border-radius: var(--radius);
  padding: 15px;
  margin-bottom: 20px;
}

/* GRID */
.grid {
  display: grid;
  gap: 10px;
}

.grid-3 {
  grid-template-columns: repeat(3, 1fr);
}

/* RADIO TILE */
.radio-box {
  border: 1px solid var(--color-border);
  padding: 10px;
  border-radius: var(--radius);
  cursor: pointer;
}

.radio-box:hover {
  border-color: var(--color-primary);
}

.radio-box input {
  display: none;
}

.radio-box.active {
  border: 2px solid var(--color-primary);
  background: #fff5f6;
}

/* FLOW */
.step {
  border: 1px solid var(--color-border);
  padding: 12px;
  border-radius: var(--radius);
  cursor: pointer;
}

.step:hover {
  border-color: var(--color-primary);
}

.arrow {
  text-align: center;
  margin: 8px 0;
}

/* COPY */
.copy-link {
  cursor: pointer;
}

/* TYPO */
h1 { margin-bottom: 20px; }
h2 { margin-bottom: 10px; }

</style>
</head>

<body>

<div class="main">
  <div class="container-wide">

    <h1>Technik Edit – Flow instrukcji</h1>

    <!-- ================= HERAUSFORDERUNG ================= -->
    <div class="container-card">
      <h2>Herausforderung</h2>
      <div class="grid grid-3" id="hGroup"></div>
    </div>

    <!-- ================= STATUS ================= -->
    <div class="container-card">
      <h2>Status</h2>
      <div class="grid grid-3" id="sGroup"></div>
    </div>

    <!-- ================= TECHNIK ================= -->
    <div class="container-card">
      <h2>Techniker</h2>
      <div class="grid grid-3" id="tGroup"></div>
    </div>

    <!-- ================= FLOW ================= -->
    <div class="container-card">
      <h2>Instrukcja (krok po kroku)</h2>
      <div id="flowBox">
        Wybierz parametry...
      </div>
    </div>

  </div>
</div>

<script>

/* ===== OPCJE ===== */
const H = {
  storno: "Storno",
  terminverschiebung: "Terminverschiebung",
  doppelauftrag: "Doppelauftrag",
  techniker_nicht_da: "Techniker nicht da"
};

const S = {
  offen: "Offen",
  angenommen: "Angenommen",
  teile: "Teile bestellt"
};

const T = {
  wkd: "WKd",
  p1: "P1 (operatec)",
  sp: "SP"
};

/* ===== FLOW (każdy przypadek = lista kroków) ===== */
const rules = {
  storno: {
    offen: {
      wkd: [
        "Wejdź do systemu WKd",
        "Znajdź zgłoszenie",
        "Anuluj zgłoszenie",
        "Potwierdź klientowi"
      ]
    }
  },

  terminverschiebung: {
    angenommen: {
      p1: [
        "Otwórz zgłoszenie w P1",
        "Skontaktuj się z technikiem",
        "Ustal nowy termin",
        "Zapisz zmiany"
      ]
    }
  }
};

/* ===== STATE ===== */
let state = {
  h: null,
  s: null,
  t: null
};

/* ===== GENERATOR RADIO ===== */
function createGroup(data, containerId, key) {
  const container = document.getElementById(containerId);

  Object.entries(data).forEach(([value, label]) => {
    const el = document.createElement("div");
    el.className = "radio-box";
    el.innerText = label;

    el.onclick = () => {
      state[key] = value;

      [...container.children].forEach(c => c.classList.remove("active"));
      el.classList.add("active");

      updateFlow();
    };

    container.appendChild(el);
  });
}

/* ===== FLOW ===== */
function updateFlow() {

  const {h, s, t} = state;

  if (!h || !s || !t) {
    document.getElementById("flowBox").innerText = "Wybierz wszystkie parametry...";
    return;
  }

  const steps = rules[h]?.[s]?.[t];

  if (!steps) {
    document.getElementById("flowBox").innerText = "Brak instrukcji.";
    return;
  }

  let html = "";

  steps.forEach((step, index) => {
    html += `<div class="step copy-link" onclick="copyText('${step}')">${step}</div>`;

    if (index < steps.length - 1) {
      html += `<div class="arrow">⬇</div>`;
    }
  });

  document.getElementById("flowBox").innerHTML = html;
}

/* ===== COPY ===== */
function copyText(text) {
  navigator.clipboard.writeText(text);
}

/* ===== INIT ===== */
createGroup(H, "hGroup", "h");
createGroup(S, "sGroup", "s");
createGroup(T, "tGroup", "t");

</script>

</body>
</html>





