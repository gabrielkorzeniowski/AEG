<!DOCTYPE html>
<html lang="pl">
<head>
  <meta charset="UTF-8">
  <title>Notatka rozmowy PRO</title>
  <link rel="stylesheet" href="aeg-theme.css">
</head>
<body>

<div class="app">
  <div class="layout" style="grid-template-columns: 1fr;">
    <div class="main">

      <div class="container-card">

        <h1>Notatka rozmowy</h1>

        <!-- ===== SEKCJA 1 ===== -->
        <div class="container-card mb-20">
          <h2>Opis zgłoszenia</h2>

          <div class="input-group">
            <label>Co się stało</label>
            <textarea id="problem"></textarea>
          </div>

          <div class="input-group">
            <label>Co już zostało zrobione</label>
            <textarea id="done"></textarea>
          </div>

          <div class="input-group">
            <label>Fehlercode</label>
            <input type="text" id="error">
          </div>

          <!-- CHECKBOXY -->
          <div class="mt-20">
            <label><input type="checkbox" value="Woda wycieka spod pralki"> Wyciek wody</label><br>
            <label><input type="checkbox" value="Urządzenie nie włącza się"> Nie włącza się</label><br>
            <label><input type="checkbox" value="Błąd na wyświetlaczu"> Błąd</label><br>
            <label><input type="checkbox" value="Głośna praca urządzenia"> Głośna praca</label>
          </div>

        </div>

        <!-- ===== LINK ===== -->
        <div class="container-card mb-20">
          <h2>Link do bazy wiedzy</h2>

          <input type="text" id="link" placeholder="Wklej link...">
        </div>

        <!-- ===== GENERUJ ===== -->
        <div class="container-card mb-20">
          <button class="btn btn-primary" onclick="generateNote()">Generuj notatkę</button>
        </div>

        <!-- ===== OUTPUT ===== -->
        <div class="container-card">
          <h2>Notatka końcowa</h2>

          <textarea id="finalNote" rows="10"></textarea>

          <button class="btn btn-secondary mt-20" onclick="copyNote()">Kopiuj</button>
        </div>

      </div>

    </div>
  </div>
</div>

<script>
function generateNote() {
  let parts = [];

  const problem = document.getElementById('problem').value.trim();
  const done = document.getElementById('done').value.trim();
  const error = document.getElementById('error').value.trim();
  const link = document.getElementById('link').value.trim();

  // TEXT INPUTS
  if (problem) parts.push(problem);
  if (done) parts.push(done);
  if (error) parts.push("Fehlercode: " + error);

  // CHECKBOXY
  document.querySelectorAll('input[type="checkbox"]:checked').forEach(cb => {
    parts.push(cb.value);
  });

  let finalParts = [];

  // SEKCJA 1
  if (parts.length > 0) {
    finalParts.push(parts.join('; '));
  }

  // LINK (tylko jeśli istnieje)
  if (link) {
    finalParts.push(link);
  }

  // KOŃCÓWKA ZAWSZE
  finalParts.push('poinformowany o bda');

  // Łączenie w jednej linii
  const finalText = finalParts.join(' *** ');

  document.getElementById('finalNote').value = finalText;
}

function copyNote() {
  const textarea = document.getElementById('finalNote');
  textarea.select();
  document.execCommand('copy');
}
</script>

</body>
</html>